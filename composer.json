{
	"name": "dataforms/dataforms",
	"description": "Build registers, smart forms and views inside Nextcloud.",
	"type": "project",
	"license": "AGPL-3.0-or-later",
	"require": {
		"php": "^8.1"
	},
	"require-dev": {
		"nextcloud/coding-standard": "^1.3",
		"nextcloud/ocp": "dev-master",
		"psalm/phar": "^5.26",
		"phpunit/phpunit": "^10.5"
	},
	"config": {
		"sort-packages": true,
		"platform": {
			"php": "8.1"
		},
		"allow-plugins": {
			"composer/package-versions-deprecated": true
		}
	},
	"autoload": {
		"psr-4": {
			"OCA\\Dataforms\\": "lib/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"OCA\\Dataforms\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"lint": "find . -name \\*.php -not -path './vendor/*' -print0 | xargs -0 -n1 php -l",
		"cs:check": "php-cs-fixer fix --dry-run --diff",
		"cs:fix": "php-cs-fixer fix",
		"psalm": "psalm.phar --no-cache",
		"test:unit": "phpunit --configuration tests/phpunit.xml",
		"test:coverage": "phpunit --configuration tests/phpunit.xml --coverage-clover coverage.xml --coverage-text=coverage.txt"
	}
}
