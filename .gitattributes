# Normalise all text to LF in the repo (consistent across OSes; keeps the
# signed app tarball reproducible). Binary assets are left untouched.
* text=auto eol=lf

*.png binary
*.jpg binary
*.gif binary
*.ico binary

# Keep dev-only files out of `git archive` exports — a secondary safety net so a
# GitHub "Download ZIP" / git-archive can't leak source or tooling. (The supported
# packaging path is krankerl / scripts/package.sh, which build js/css first; a bare
# git archive omits those and is not a runnable app.) Runtime + docs still ship.
/.github export-ignore
/.tx export-ignore
/src export-ignore
/tests export-ignore
/scripts export-ignore
/build export-ignore
/.editorconfig export-ignore
/.eslintrc.cjs export-ignore
/.gitattributes export-ignore
/.gitignore export-ignore
/.npmrc export-ignore
/.php-cs-fixer.dist.php export-ignore
/composer.json export-ignore
/composer.lock export-ignore
/krankerl.toml export-ignore
/Makefile export-ignore
/package.json export-ignore
/package-lock.json export-ignore
/playwright.config.js export-ignore
/psalm.xml export-ignore
/stylelint.config.cjs export-ignore
/tsconfig.json export-ignore
/vite.config.js export-ignore
/vitest.config.js export-ignore
*.map export-ignore
*.docx export-ignore
*.cache export-ignore
