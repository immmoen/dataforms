<?xml version="1.0" encoding="UTF-8"?>
<!-- SPDX-License-Identifier: AGPL-3.0-or-later -->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
		 xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/10.5/phpunit.xsd"
		 bootstrap="bootstrap.php"
		 colors="true"
		 failOnWarning="true"
		 failOnRisky="true">
	<testsuites>
		<testsuite name="unit">
			<directory>unit</directory>
		</testsuite>
	</testsuites>
	<source>
		<include>
			<directory suffix=".php">../lib</directory>
		</include>
		<exclude>
			<!-- One-shot schema transforms; verified by the cross-DB integration job. -->
			<directory suffix=".php">../lib/Migration</directory>
			<!-- DI container bootstrap; exercised by integration, not unit-testable. -->
			<file>../lib/AppInfo/Application.php</file>
		</exclude>
	</source>
</phpunit>
