<!--
	Integration suite: mapper tests against a REAL Nextcloud database, built by
	the app's own migrations. Runs only inside a Nextcloud instance (the CI
	3-database matrix, or a local nextcloud container) — see integration/bootstrap.php.
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
		 xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/10.5/phpunit.xsd"
		 bootstrap="integration/bootstrap.php"
		 colors="true"
		 failOnWarning="true"
		 failOnRisky="true">
	<testsuites>
		<testsuite name="integration">
			<directory>integration</directory>
		</testsuite>
	</testsuites>
	<!-- Same source scope as the unit config: the per-touched-file coverage gate
	     (.github/scripts/touched_files_coverage.py) unions this clover with the
	     unit one, so mapper coverage (measured only here) counts. -->
	<source>
		<include>
			<directory suffix=".php">../lib</directory>
		</include>
		<exclude>
			<directory suffix=".php">../lib/Migration</directory>
			<file>../lib/AppInfo/Application.php</file>
		</exclude>
	</source>
</phpunit>
