{
	"_comment": "SPDX-License-Identifier: AGPL-3.0-or-later. Shared fixtures asserting the JS (src/rules) and PHP (lib/Rules) evaluators agree. Loaded by both test suites.",
	"expression": [
		{ "name": "multiply", "expr": "likelihood * impact", "values": { "likelihood": 3, "impact": 4 }, "expect": 12 },
		{ "name": "precedence", "expr": "2 + 3 * 4", "values": {}, "expect": 14 },
		{ "name": "parentheses", "expr": "(2 + 3) * 4", "values": {}, "expect": 20 },
		{ "name": "round", "expr": "round(price * 1.2, 2)", "values": { "price": 10 }, "expect": 12 },
		{ "name": "round-half", "expr": "round((a + b) / 2, 1)", "values": { "a": 3, "b": 4 }, "expect": 3.5 },
		{ "name": "sum", "expr": "sum(a, b, c)", "values": { "a": 1, "b": 2, "c": 3 }, "expect": 6 },
		{ "name": "min-max", "expr": "max(a, b) - min(a, b)", "values": { "a": 9, "b": 2 }, "expect": 7 },
		{ "name": "concat", "expr": "concat(first, ' ', last)", "values": { "first": "Ada", "last": "Lovelace" }, "expect": "Ada Lovelace" },
		{ "name": "string-plus", "expr": "first + last", "values": { "first": "ab", "last": "cd" }, "expect": "abcd" },
		{ "name": "if-true", "expr": "if(qty > 10, 'bulk', 'single')", "values": { "qty": 20 }, "expect": "bulk" },
		{ "name": "if-false", "expr": "if(qty > 10, 'bulk', 'single')", "values": { "qty": 5 }, "expect": "single" },
		{ "name": "comparison", "expr": "score >= 8", "values": { "score": 12 }, "expect": true },
		{ "name": "abs", "expr": "abs(a - b)", "values": { "a": 3, "b": 10 }, "expect": 7 },
		{ "name": "upper", "expr": "upper(name)", "values": { "name": "edps" }, "expect": "EDPS" },
		{ "name": "coalesce", "expr": "coalesce(a, b, 'fallback')", "values": { "a": "", "b": "second" }, "expect": "second" },
		{ "name": "div-by-zero-safe", "expr": "a / b", "values": { "a": 10, "b": 0 }, "expect": 0 },

		{ "name": "len", "expr": "len(name)", "values": { "name": "hello" }, "expect": 5 },
		{ "name": "lower", "expr": "lower(name)", "values": { "name": "EDPS" }, "expect": "edps" },
		{ "name": "number-cast", "expr": "number(x) + 1", "values": { "x": "41" }, "expect": 42 },
		{ "name": "number-non-numeric-is-zero", "expr": "number(x)", "values": { "x": "abc" }, "expect": 0 },
		{ "name": "modulo", "expr": "a % b", "values": { "a": 17, "b": 5 }, "expect": 2 },
		{ "name": "modulo-by-zero-safe", "expr": "a % b", "values": { "a": 7, "b": 0 }, "expect": 0 },
		{ "name": "eq-op", "expr": "a == b", "values": { "a": 2, "b": 2 }, "expect": true },
		{ "name": "neq-op", "expr": "a != b", "values": { "a": 2, "b": 3 }, "expect": true },
		{ "name": "lt-op", "expr": "a < b", "values": { "a": 1, "b": 2 }, "expect": true },
		{ "name": "gt-op", "expr": "a > b", "values": { "a": 5, "b": 2 }, "expect": true },
		{ "name": "lte-op", "expr": "a <= b", "values": { "a": 2, "b": 2 }, "expect": true },
		{ "name": "unary-minus", "expr": "-a + 10", "values": { "a": 4 }, "expect": 6 },
		{ "name": "bool-literal-false", "expr": "if(false, 1, 2)", "values": {}, "expect": 2 },
		{ "name": "bool-literal-true", "expr": "if(true, 1, 2)", "values": {}, "expect": 1 },
		{ "name": "coalesce-all-empty-is-null", "expr": "coalesce(a, b)", "values": { "a": "", "b": "" }, "expect": null },
		{ "name": "string-equality", "expr": "name == 'edps'", "values": { "name": "edps" }, "expect": true },
		{ "name": "nested-if", "expr": "if(n > 100, 'huge', if(n > 10, 'big', 'small'))", "values": { "n": 50 }, "expect": "big" }
	],
	"rules": [
		{
			"name": "compute-risk-score",
			"fields": [
				{ "machineName": "likelihood", "type": "number" },
				{ "machineName": "impact", "type": "number" },
				{ "machineName": "risk", "type": "number" }
			],
			"rules": [{ "effect": "compute", "target": "risk", "expression": "likelihood * impact" }],
			"values": { "likelihood": 3, "impact": 4 },
			"expect": { "values": { "risk": 12 }, "errors": {} }
		},
		{
			"name": "compute-bad-expression-is-null",
			"fields": [{ "machineName": "x", "type": "number" }, { "machineName": "out", "type": "number" }],
			"rules": [{ "effect": "compute", "target": "out", "expression": "1 +" }],
			"values": { "x": 2 },
			"expect": { "values": { "out": 0 } }
		},
		{
			"name": "conditional-require-triggered",
			"fields": [
				{ "machineName": "basis", "type": "select" },
				{ "machineName": "dpia", "type": "text" }
			],
			"rules": [{ "effect": "require", "target": "dpia", "conditions": { "logic": "and", "rules": [{ "field": "basis", "op": "eq", "value": "public" }] } }],
			"values": { "basis": "public" },
			"expect": { "required": { "dpia": true }, "errors": { "dpia": "This field is required" } }
		},
		{
			"name": "conditional-require-not-triggered",
			"fields": [
				{ "machineName": "basis", "type": "select" },
				{ "machineName": "dpia", "type": "text" }
			],
			"rules": [{ "effect": "require", "target": "dpia", "conditions": { "logic": "and", "rules": [{ "field": "basis", "op": "eq", "value": "public" }] } }],
			"values": { "basis": "consent" },
			"expect": { "errors": {} }
		},
		{
			"name": "show-hides-field",
			"fields": [
				{ "machineName": "special", "type": "boolean" },
				{ "machineName": "categories", "type": "text" }
			],
			"rules": [{ "effect": "show", "target": "categories", "conditions": { "logic": "and", "rules": [{ "field": "special", "op": "eq", "value": true }] } }],
			"values": { "special": false },
			"expect": { "visible": { "categories": false } }
		},
		{
			"name": "show-reveals-field",
			"fields": [
				{ "machineName": "special", "type": "boolean" },
				{ "machineName": "categories", "type": "text" }
			],
			"rules": [{ "effect": "show", "target": "categories", "conditions": { "logic": "and", "rules": [{ "field": "special", "op": "eq", "value": true }] } }],
			"values": { "special": true },
			"expect": { "visible": { "categories": true } }
		},
		{
			"name": "validate-range",
			"fields": [{ "machineName": "score", "type": "number" }],
			"rules": [{ "effect": "validate", "target": "score", "validation": { "kind": "range", "min": 0, "max": 10, "message": "0-10 only" } }],
			"values": { "score": 15 },
			"expect": { "errors": { "score": "0-10 only" } }
		},
		{
			"name": "validate-range-ok",
			"fields": [{ "machineName": "score", "type": "number" }],
			"rules": [{ "effect": "validate", "target": "score", "validation": { "kind": "range", "min": 0, "max": 10, "message": "0-10 only" } }],
			"values": { "score": 5 },
			"expect": { "errors": {} }
		},
		{
			"name": "validate-regex-ok",
			"fields": [{ "machineName": "ref", "type": "text" }],
			"rules": [{ "effect": "validate", "target": "ref", "validation": { "kind": "regex", "pattern": "^DPIA-[0-9]{4}-[0-9]+$", "message": "bad format" } }],
			"values": { "ref": "DPIA-2026-7" },
			"expect": { "errors": {} }
		},
		{
			"name": "validate-regex-fail",
			"fields": [{ "machineName": "ref", "type": "text" }],
			"rules": [{ "effect": "validate", "target": "ref", "validation": { "kind": "regex", "pattern": "^DPIA-[0-9]{4}-[0-9]+$", "message": "bad format" } }],
			"values": { "ref": "nope" },
			"expect": { "errors": { "ref": "bad format" } }
		},
		{
			"name": "validate-expression-fail",
			"fields": [{ "machineName": "score", "type": "number" }],
			"rules": [{ "effect": "validate", "target": "score", "validation": { "kind": "expression", "expression": "score < 100", "message": "too high" } }],
			"values": { "score": 200 },
			"expect": { "errors": { "score": "too high" } }
		},
		{
			"name": "validate-skips-empty-value",
			"fields": [{ "machineName": "ref", "type": "text" }],
			"rules": [{ "effect": "validate", "target": "ref", "validation": { "kind": "regex", "pattern": "^X$", "message": "bad" } }],
			"values": { "ref": "" },
			"expect": { "errors": {} }
		},
		{
			"name": "set-value-default-applied",
			"fields": [{ "machineName": "tier", "type": "select" }, { "machineName": "fee", "type": "number" }],
			"rules": [{ "effect": "set_value", "target": "fee", "value": 100, "conditions": { "logic": "and", "rules": [{ "field": "tier", "op": "eq", "value": "gold" }] } }],
			"values": { "tier": "gold" },
			"expect": { "values": { "fee": 100 } }
		},
		{
			"name": "set-value-keeps-existing",
			"fields": [{ "machineName": "tier", "type": "select" }, { "machineName": "fee", "type": "number" }],
			"rules": [{ "effect": "set_value", "target": "fee", "value": 100, "conditions": { "logic": "and", "rules": [{ "field": "tier", "op": "eq", "value": "gold" }] } }],
			"values": { "tier": "gold", "fee": 7 },
			"expect": { "values": { "fee": 7 } }
		},
		{
			"name": "or-conditions",
			"fields": [
				{ "machineName": "a", "type": "text" },
				{ "machineName": "b", "type": "text" },
				{ "machineName": "flag", "type": "text" }
			],
			"rules": [{ "effect": "require", "target": "flag", "conditions": { "logic": "or", "rules": [{ "field": "a", "op": "eq", "value": "x" }, { "field": "b", "op": "eq", "value": "y" }] } }],
			"values": { "a": "no", "b": "y" },
			"expect": { "required": { "flag": true } }
		},
		{
			"name": "require-neq",
			"fields": [{ "machineName": "status", "type": "select" }, { "machineName": "reason", "type": "text" }],
			"rules": [{ "effect": "require", "target": "reason", "conditions": { "logic": "and", "rules": [{ "field": "status", "op": "neq", "value": "open" }] } }],
			"values": { "status": "closed" },
			"expect": { "required": { "reason": true } }
		},
		{
			"name": "require-gt",
			"fields": [{ "machineName": "amount", "type": "number" }, { "machineName": "approval", "type": "text" }],
			"rules": [{ "effect": "require", "target": "approval", "conditions": { "logic": "and", "rules": [{ "field": "amount", "op": "gt", "value": 1000 }] } }],
			"values": { "amount": 5000 },
			"expect": { "required": { "approval": true } }
		},
		{
			"name": "require-gte-and-lte",
			"fields": [{ "machineName": "amount", "type": "number" }, { "machineName": "mid", "type": "text" }],
			"rules": [{ "effect": "require", "target": "mid", "conditions": { "logic": "and", "rules": [{ "field": "amount", "op": "gte", "value": 10 }, { "field": "amount", "op": "lte", "value": 100 }] } }],
			"values": { "amount": 50 },
			"expect": { "required": { "mid": true } }
		},
		{
			"name": "require-lt",
			"fields": [{ "machineName": "amount", "type": "number" }, { "machineName": "low", "type": "text" }],
			"rules": [{ "effect": "require", "target": "low", "conditions": { "logic": "and", "rules": [{ "field": "amount", "op": "lt", "value": 10 }] } }],
			"values": { "amount": 3 },
			"expect": { "required": { "low": true } }
		},
		{
			"name": "require-contains",
			"fields": [{ "machineName": "tags", "type": "text" }, { "machineName": "extra", "type": "text" }],
			"rules": [{ "effect": "require", "target": "extra", "conditions": { "logic": "and", "rules": [{ "field": "tags", "op": "contains", "value": "vip" }] } }],
			"values": { "tags": "a,vip,b" },
			"expect": { "required": { "extra": true } }
		},
		{
			"name": "require-in",
			"fields": [{ "machineName": "country", "type": "select" }, { "machineName": "vat", "type": "text" }],
			"rules": [{ "effect": "require", "target": "vat", "conditions": { "logic": "and", "rules": [{ "field": "country", "op": "in", "value": ["FR", "DE"] }] } }],
			"values": { "country": "DE" },
			"expect": { "required": { "vat": true } }
		},
		{
			"name": "require-matches",
			"fields": [{ "machineName": "code", "type": "text" }, { "machineName": "sub", "type": "text" }],
			"rules": [{ "effect": "require", "target": "sub", "conditions": { "logic": "and", "rules": [{ "field": "code", "op": "matches", "value": "^A[0-9]+$" }] } }],
			"values": { "code": "A12" },
			"expect": { "required": { "sub": true } }
		},
		{
			"name": "require-is-not-empty",
			"fields": [{ "machineName": "note", "type": "text" }, { "machineName": "ack", "type": "boolean" }],
			"rules": [{ "effect": "require", "target": "ack", "conditions": { "logic": "and", "rules": [{ "field": "note", "op": "isNotEmpty" }] } }],
			"values": { "note": "x" },
			"expect": { "required": { "ack": true } }
		},
		{
			"name": "require-is-empty",
			"fields": [{ "machineName": "note", "type": "text" }, { "machineName": "ask", "type": "text" }],
			"rules": [{ "effect": "require", "target": "ask", "conditions": { "logic": "and", "rules": [{ "field": "note", "op": "isEmpty" }] } }],
			"values": { "note": "" },
			"expect": { "required": { "ask": true } }
		},
		{
			"name": "require-eq-numeric",
			"fields": [{ "machineName": "amount", "type": "number" }, { "machineName": "tag", "type": "text" }],
			"rules": [{ "effect": "require", "target": "tag", "conditions": { "logic": "and", "rules": [{ "field": "amount", "op": "eq", "value": 50 }] } }],
			"values": { "amount": 50 },
			"expect": { "required": { "tag": true } }
		},
		{
			"name": "require-contains-array-value",
			"fields": [{ "machineName": "tags", "type": "multiselect" }, { "machineName": "more", "type": "text" }],
			"rules": [{ "effect": "require", "target": "more", "conditions": { "logic": "and", "rules": [{ "field": "tags", "op": "contains", "value": "vip" }] } }],
			"values": { "tags": ["a", "vip"] },
			"expect": { "required": { "more": true } }
		},
		{
			"name": "validate-range-below-min",
			"fields": [{ "machineName": "score", "type": "number" }],
			"rules": [{ "effect": "validate", "target": "score", "validation": { "kind": "range", "min": 0, "max": 10, "message": "0-10 only" } }],
			"values": { "score": -5 },
			"expect": { "errors": { "score": "0-10 only" } }
		}
	]
}
