<?xml version="1.0"?>
<!-- SPDX-License-Identifier: AGPL-3.0-or-later -->
<psalm
	errorLevel="2"
	resolveFromConfigFile="true"
	findUnusedBaselineEntry="true"
	findUnusedCode="true"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns="https://getpsalm.org/schema/config"
	xsi:schemaLocation="https://getpsalm.org/schema/config vendor/vimeo/psalm/config.xsd"
>
	<projectFiles>
		<directory name="lib" />
		<ignoreFiles>
			<directory name="vendor" />
		</ignoreFiles>
	</projectFiles>
	<extraFiles>
		<directory name="vendor" />
	</extraFiles>
	<issueHandlers>
		<UndefinedClass>
			<errorLevel type="suppress">
				<referencedClass name="OC" />
				<!-- sabre/vobject is a Nextcloud core dependency, not in the app's analysis vendor. -->
				<referencedClass name="Sabre\VObject\Component\VCalendar" />
			</errorLevel>
		</UndefinedClass>
		<!--
			Framework/stub noise, not app bugs:
			- The migration types (OCP\DB\ISchemaWrapper etc.) document their
			  parameters as Doctrine\DBAL\Schema\* in docblocks, but Doctrine DBAL
			  is not installed for static analysis (it's an internal NC dependency).
			- The OCP stubs reference legacy OC\… internals (e.g. oc\hooks\emitter)
			  that the analysis-only nextcloud/ocp package does not ship.
			- Nextcloud Entity properties are populated by QBMapper hydration via
			  __call, not in the constructor — the standard NC Entity pattern.
		-->
		<UndefinedDocblockClass>
			<errorLevel type="suppress">
				<referencedClass name="Doctrine\DBAL\Schema\Table" />
				<referencedClass name="Doctrine\DBAL\Schema\Schema" />
			</errorLevel>
		</UndefinedDocblockClass>
		<MissingDependency errorLevel="suppress" />
		<PropertyNotSetInConstructor errorLevel="suppress" />
		<!--
			findUnusedCode is enabled (above) to surface genuinely dead code —
			unused local variables, unreferenced private methods/properties, etc.
			The categories below, however, are false positives by construction in
			a Nextcloud app and are suppressed so the useful signal is not drowned:
			- UnusedClass / PossiblyUnusedMethod: controllers, background jobs,
			  listeners, settings, mappers and their constructors are instantiated
			  by the DI container, the router and the event dispatcher — never by
			  `new` in app code — so psalm's call graph cannot see the entry points.
			- PossiblyUnusedProperty: Entity properties are written by QBMapper
			  hydration (via __call) and read through jsonSerialize(), neither of
			  which psalm models.
			- PossiblyUnusedReturnValue: a method returning a useful value that some
			  callers legitimately ignore is not a defect.
			- UnnecessaryVarAnnotation: the `@var ISchemaWrapper $schema` line is the
			  conventional Nextcloud migration idiom; psalm reads it as redundant
			  against the OCP stub, but it documents the closure result for readers.
		-->
		<UnusedClass errorLevel="suppress" />
		<PossiblyUnusedMethod errorLevel="suppress" />
		<PossiblyUnusedProperty errorLevel="suppress" />
		<PossiblyUnusedReturnValue errorLevel="suppress" />
		<UnnecessaryVarAnnotation errorLevel="suppress" />
		<!--
			Defensive (string)/(int)/(bool) casts on values that arrive as `mixed`
			from JSON / request input are intentional, even where an optimistic
			docblock says the type is already narrowed. Keeping them hardens the
			service layer against malformed input, so the "redundant cast" family
			is not treated as an error here.
		-->
		<RedundantCastGivenDocblockType errorLevel="suppress" />
		<RedundantCast errorLevel="suppress" />
	</issueHandlers>
</psalm>
