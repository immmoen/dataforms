{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"lib": [
			"ES2022",
			"DOM",
			"DOM.Iterable"
		],
		"types": [
			"vite/client"
		],
		"baseUrl": ".",
		"paths": {
			"@/*": [
				"src/*"
			]
		},
		"checkJs": true,
		"allowJs": true,
		"noImplicitAny": false,
		"strictNullChecks": true,
		"useUnknownInCatchVariables": false
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.vue",
		"src/**/*.js"
	],
	"exclude": [
		"node_modules",
		"build",
		"js",
		"src/**/*.spec.js",
		"tests"
	]
}